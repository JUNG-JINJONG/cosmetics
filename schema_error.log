-- 6. 글로벌 정산 및 환율 관리 (Global Settlements)
CREATE TABLE IF NOT EXISTS exchange_rates (
    rate_id SERIAL PRIMARY KEY,
    from_currency VARCHAR(10) NOT NULL, -- 예: 'USD'
    to_currency VARCHAR(10) NOT NULL,   -- 예: 'KRW'
    base_rate DECIMAL(15, 6) NOT NULL,  -- 환율 (1 From = N To)
    provider VARCHAR(50),               -- 정보 제공처
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS settlements (
    settlement_id SERIAL PRIMARY KEY,
    order_id INTEGER REFERENCES orders(order_id) ON DELETE CASCADE,
    buyer_id INTEGER REFERENCES buyer(buyer_id) ON DELETE SET NULL,
    total_amount DECIMAL(15, 2) NOT NULL,     -- 총 결제액
    currency VARCHAR(10) DEFAULT 'USD',
    tax_amount DECIMAL(15, 2) DEFAULT 0,      -- 세금
    fee_amount DECIMAL(15, 2) DEFAULT 0,      -- 플랫폼/결제 수수료
    net_amount DECIMAL(15, 2) NOT NULL,      -- 최종 정산액 (판매자 수익 = 총액 - 세금 - 수수료)
    settlement_status_code VARCHAR(10) DEFAULT 'Pending', -- Pending, Completed, Canceled
    paid_at TIMESTAMP WITH TIME ZONE,        -- 실제 정산 완료일
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

