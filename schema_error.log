-- 1.1 파트너 레이팅 및 관리 (Partner Ratings)
CREATE TABLE IF NOT EXISTS partner_ratings (
    rating_id SERIAL PRIMARY KEY,
    target_company_id INTEGER REFERENCES company(company_id) ON DELETE CASCADE,
    reviewer_buyer_id INTEGER REFERENCES buyer(buyer_id) ON DELETE SET NULL,
    score NUMERIC(2, 1) CHECK (score >= 1.0 AND score <= 5.0),
    review_text TEXT,
    evaluation_criteria JSONB, -- 예: {"quality": 5, "communication": 4, "delivery": 5}
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

COMMENT ON TABLE partner_ratings IS '업체 간 신용도 및 파트너십 평가 (레이팅)';
COMMENT ON COLUMN partner_ratings.rating_id IS '평가 고유 식별 번호';
COMMENT ON COLUMN partner_ratings.target_company_id IS '평가를 받는 회사의 ID';
COMMENT ON COLUMN partner_ratings.reviewer_buyer_id IS '평가를 남긴 사용자 ID';
COMMENT ON COLUMN partner_ratings.score IS '종합 별점 (1.0 ~ 5.0)';
COMMENT ON COLUMN partner_ratings.review_text IS '세부 리뷰 텍스트';
COMMENT ON COLUMN partner_ratings.evaluation_criteria IS '세부 평가 항목 (품질, 소통 등 JSON)';

-- 2.1 제형-용기 적합성 테스트 (Compatibility Tests - C/T)
CREATE TABLE IF NOT EXISTS compatibility_tests (
    test_id SERIAL PRIMARY KEY,
    inquiry_id INTEGER REFERENCES inquiries(inquiry_id) ON DELETE CASCADE,
    cosmax_pkg_item_id INTEGER REFERENCES cosmax_pkg_items(cosmax_pkg_item_id) ON DELETE CASCADE,
    test_result TEXT,
    status VARCHAR(50) DEFAULT 'Testing', -- Testing, Pass, Fail
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

COMMENT ON TABLE compatibility_tests IS '제형-용기 적합성 및 안정성 테스트 결과';
COMMENT ON COLUMN compatibility_tests.test_id IS '테스트 식별 번호';
COMMENT ON COLUMN compatibility_tests.inquiry_id IS '제형 의뢰 ID';
COMMENT ON COLUMN compatibility_tests.cosmax_pkg_item_id IS '선정된 패키징 라이브러리 ID';
COMMENT ON COLUMN compatibility_tests.status IS '테스트 진행 상태';

-- 2.2 글로벌 컴플라이언스 가이드 (Global Compliance Rules)
CREATE TABLE IF NOT EXISTS compliance_rules (
    rule_id SERIAL PRIMARY KEY,
    country_code VARCHAR(10) NOT NULL,
    ingredient_name VARCHAR(255) NOT NULL,
    restriction_type VARCHAR(50) NOT NULL, -- Banned, Restricted, Allowed
    max_concentration VARCHAR(50),
    guideline_text TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

COMMENT ON TABLE compliance_rules IS '글로벌 성분 규제 정보 (Compliance)';
COMMENT ON COLUMN compliance_rules.rule_id IS '규제ID (PK)';
COMMENT ON COLUMN compliance_rules.country_code IS '국가코드';
COMMENT ON COLUMN compliance_rules.ingredient_name IS '성분명';
COMMENT ON COLUMN compliance_rules.restriction_type IS '제한유형 (Banned, Restricted 등)';
COMMENT ON COLUMN compliance_rules.max_concentration IS '최대배합한도';
COMMENT ON COLUMN compliance_rules.guideline_text IS '가이드라인상세';
COMMENT ON COLUMN compliance_rules.created_at IS '등록일시';
COMMENT ON COLUMN compliance_rules.updated_at IS '수정일시';

-- 2.3 상세 문진표 (Inquiry Questions - Target Efficacy, Concept Ingredients, etc.)
CREATE TABLE IF NOT EXISTS inquiry_questions (
    questionnaire_id SERIAL PRIMARY KEY,
    inquiry_id INTEGER REFERENCES inquiries(inquiry_id) ON DELETE CASCADE,
    category_id INTEGER REFERENCES category(category_id) ON DELETE CASCADE,
    score INTEGER,
    comments TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

COMMENT ON TABLE inquiry_questions IS '의뢰 상세 문진 매핑 (Inquiry Questions)';
COMMENT ON COLUMN inquiry_questions.questionnaire_id IS '문진일련번호 (PK)';
COMMENT ON COLUMN inquiry_questions.inquiry_id IS '의뢰ID (FK: inquiries)';
COMMENT ON COLUMN inquiry_questions.category_id IS '항목카테고리ID (FK: category)';
COMMENT ON COLUMN inquiry_questions.score IS '항목중요도점수';
COMMENT ON COLUMN inquiry_questions.comments IS '추가의견';
COMMENT ON COLUMN inquiry_questions.created_at IS '생성일시';

COMMENT ON TABLE ingredients IS '원료 마스터 사전 (Ingredient Catalog)';
COMMENT ON COLUMN ingredients.ingredient_id IS '원료ID (PK)';
COMMENT ON COLUMN ingredients.name IS '원료명(국문/일반명)';
COMMENT ON COLUMN ingredients.inci_name IS '단일성분명(INCI)';
COMMENT ON COLUMN ingredients.cas_no IS '화학물질번호(CAS)';
COMMENT ON COLUMN ingredients.function IS '주요기능';
COMMENT ON COLUMN ingredients.ewg_grade IS 'EWG등급 (1-10)';
COMMENT ON COLUMN ingredients.sensory_attribute_vector IS '원료감각벡터 (15차원)';
COMMENT ON COLUMN ingredients.created_at IS '등록일시';
COMMENT ON COLUMN ingredients.updated_at IS '수정일시';

COMMENT ON TABLE ingredients_sensory_attribute IS '원료별 감각 지표 (Ingredient Sensory)';
COMMENT ON COLUMN ingredients_sensory_attribute.ingredients_sensory_attribute_id IS '속성ID (PK)';
COMMENT ON COLUMN ingredients_sensory_attribute.ingredient_id IS '원료ID (FK: ingredients)';
