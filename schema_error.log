-- 4. AI 컨설팅 결과 이력 (AI Consulting History)
CREATE TABLE IF NOT EXISTS consulting_reports (
    report_id SERIAL PRIMARY KEY,
    inquiry_id INTEGER REFERENCES inquiries(inquiry_id) ON DELETE CASCADE,
    recommended_asset_id INTEGER REFERENCES cosmax_r_and_d_assets(cosmax_r_and_d_asset_id) ON DELETE SET NULL,
    report_content TEXT NOT NULL,
    matching_scores JSONB, -- 당시 계산된 후보군별 점수 리스트
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

COMMENT ON TABLE consulting_reports IS 'AI 개발 컨설팅 리포트 아카이브';
COMMENT ON COLUMN consulting_reports.report_id IS '리포트ID (PK)';
COMMENT ON COLUMN consulting_reports.inquiry_id IS '의뢰ID (FK: inquiries)';
COMMENT ON COLUMN consulting_reports.recommended_asset_id IS '추천자산ID (FK: cosmax_r_and_d_assets)';
COMMENT ON COLUMN consulting_reports.report_content IS '리포트전문내용';
COMMENT ON COLUMN consulting_reports.matching_scores IS '매칭점수데이터(JSON)';
COMMENT ON COLUMN consulting_reports.created_at IS '생성일시';

-- 4.1 스마트 견적 관리 (Quotation Management)
CREATE TABLE IF NOT EXISTS quotations (
    quotation_id SERIAL PRIMARY KEY,
    inquiry_id INTEGER REFERENCES inquiries(inquiry_id) ON DELETE SET NULL,
    buyer_id INTEGER REFERENCES buyer(buyer_id) ON DELETE CASCADE,
    company_id INTEGER REFERENCES company(company_id) ON DELETE CASCADE, -- 공급사 ID
    status VARCHAR(50) DEFAULT 'Draft', -- Draft, Sent, Confirmed, Expired, Canceled
    total_estimated_amount DECIMAL(15, 2) DEFAULT 0,
    currency VARCHAR(10) DEFAULT 'USD',
    valid_until TIMESTAMP WITH TIME ZONE,
    comments TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS quotation_items (
    quotation_item_id SERIAL PRIMARY KEY,
    quotation_id INTEGER REFERENCES quotations(quotation_id) ON DELETE CASCADE,
    product_id INTEGER REFERENCES product(product_id) ON DELETE SET NULL,
    cosmax_r_and_d_asset_id INTEGER REFERENCES cosmax_r_and_d_assets(cosmax_r_and_d_asset_id) ON DELETE SET NULL, -- 제형 직접 선택시
    quantity INTEGER NOT NULL,
    unit_price DECIMAL(12, 2) NOT NULL,
    discount_rate DECIMAL(5, 2) DEFAULT 0, -- 할인율 (%%)
    discount_amount DECIMAL(15, 2) DEFAULT 0, -- 할인금액 (총합에서 차감될 금액)
    subtotal DECIMAL(15, 2) NOT NULL, -- (개당 단가 * 수량) - 할인금액
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

COMMENT ON TABLE quotations IS '스마트 견적 마스터 (Quotation)';
COMMENT ON COLUMN quotations.quotation_id IS '견적ID (PK)';
COMMENT ON COLUMN quotations.inquiry_id IS '의뢰ID (FK: inquiries)';
COMMENT ON COLUMN quotations.buyer_id IS '사용자ID (FK: buyer)';
COMMENT ON COLUMN quotations.company_id IS '공급업체ID (FK: company)';
COMMENT ON COLUMN quotations.status IS '견적진행상태';
COMMENT ON COLUMN quotations.total_estimated_amount IS '총합계견적액';
COMMENT ON COLUMN quotations.currency IS '통화단위';
COMMENT ON COLUMN quotations.valid_until IS '견적유효기한';
COMMENT ON COLUMN quotations.comments IS '견적특이사항';
COMMENT ON COLUMN quotations.created_at IS '생성일시';
COMMENT ON COLUMN quotations.updated_at IS '수정일시';

COMMENT ON TABLE quotation_items IS '상세 견적 항목 (Quotation Items)';
COMMENT ON COLUMN quotation_items.quotation_item_id IS '항목ID (PK)';
COMMENT ON COLUMN quotation_items.quotation_id IS '견적ID (FK: quotations)';
COMMENT ON COLUMN quotation_items.product_id IS '상품ID (FK: product)';
COMMENT ON COLUMN quotation_items.cosmax_r_and_d_asset_id IS 'R&D자산ID (FK: cosmax_r_and_d_assets)';
COMMENT ON COLUMN quotation_items.quantity IS '요청수량';
COMMENT ON COLUMN quotation_items.unit_price IS '적용단가';
COMMENT ON COLUMN quotation_items.discount_rate IS '할인율(%%)';
COMMENT ON COLUMN quotation_items.discount_amount IS '할인금액';
COMMENT ON COLUMN quotation_items.subtotal IS '항목별소계 (수량*단가 - 할인)';
COMMENT ON COLUMN quotation_items.created_at IS '생성일시';

-- 4.2 생산 및 공정 관리 (Production Scheduling)
CREATE TABLE IF NOT EXISTS production_schedules (
    schedule_id SERIAL PRIMARY KEY,
    order_id INTEGER REFERENCES orders(order_id) ON DELETE CASCADE,
    product_id INTEGER REFERENCES product(product_id) ON DELETE SET NULL,
    batch_no VARCHAR(100), -- 생산 배치 번호
    line_no VARCHAR(50),  -- 생산 라인 번호
    planned_start_date DATE,
    planned_end_date DATE,
    actual_start_date DATE,
    actual_end_date DATE,
    status VARCHAR(50) DEFAULT 'Scheduled', -- Scheduled, In-Progress, Finished, QC-Pending
    produced_quantity INTEGER DEFAULT 0,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 4.3 물류 및 배송 추적 (Shipments & Tracking)
CREATE TABLE IF NOT EXISTS shipments (
    shipment_id SERIAL PRIMARY KEY,
    order_id INTEGER REFERENCES orders(order_id) ON DELETE CASCADE,
    shipping_company VARCHAR(100),
    tracking_number VARCHAR(100),
    shipped_at TIMESTAMP WITH TIME ZONE,
    estimated_delivery DATE,
    status VARCHAR(50) DEFAULT 'Preparing', -- Preparing, Shipped, In-Transit, Delivered
    recipient_name VARCHAR(100),
    shipping_address TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

