(psycopg2.errors.UndefinedTable) relation "production_schedules" does not exist

[SQL: -- Cosmetics-B2B 통합 데이터베이스 스키마
-- 기반: PostgreSQL

-- 0. 국가 정보 (Localization)
CREATE TABLE IF NOT EXISTS countries (
    country_code CHAR(2) PRIMARY KEY,
    country_name VARCHAR(100) NOT NULL
);

-- 0.1 업체 정보 (Company Information)
CREATE TABLE IF NOT EXISTS company (
    company_id SERIAL PRIMARY KEY,
    company_name VARCHAR(255) NOT NULL,
    business_number VARCHAR(50) UNIQUE NOT NULL,
    ceo_name VARCHAR(100),
    address TEXT,
    factory_address TEXT,
    contact_phone VARCHAR(50),
    contact_email VARCHAR(255),
    company_type VARCHAR(50) CHECK (company_type IN ('제조사(OEM/ODM)', '브랜드사', '원료사')),
    specialty VARCHAR(255),
    certifications JSONB,
    is_verified BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 0.2 카테고리 정보 (Category Information)
CREATE TABLE IF NOT EXISTS category (
    category_id SERIAL PRIMARY KEY,
    group_code1 VARCHAR(2),
    group_code2 VARCHAR(2),
    group_code3 VARCHAR(2) DEFAULT '00',
    group_code4 VARCHAR(2) DEFAULT '00',
    group_code1_desc VARCHAR(1024),
    group_code2_desc VARCHAR(1024),
    group_code3_desc VARCHAR(1024),
    group_code4_desc VARCHAR(1024),
    code VARCHAR(10),
    code_desc VARCHAR(1024),
    code_name_kr VARCHAR(100),
    code_name_eng VARCHAR(100),
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 1. 공통 기반 인프라 (Core Infrastructure)
CREATE TABLE IF NOT EXISTS buyer (
    buyer_id SERIAL PRIMARY KEY,
    email VARCHAR(255) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    role VARCHAR(50) NOT NULL CHECK (role IN ('Admin', 'Manufacturer', 'Client')),
    name VARCHAR(100),
    phone VARCHAR(50),
    country_code CHAR(2) REFERENCES countries(country_code),
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 2. 제품 개발 및 프로젝트 (Development & Projects)

-- 제품 개발 의뢰 (Inquiry & Requests)
CREATE TABLE IF NOT EXISTS inquiries (
    inquiry_id SERIAL PRIMARY KEY,
    buyer_id INTEGER REFERENCES buyer(buyer_id),
    company_id INTEGER REFERENCES company(company_id) ON DELETE SET NULL,
    brand_name VARCHAR(255) NOT NULL,
    registration_num VARCHAR(100),
    website_url TEXT,
    item_type VARCHAR(100),
    target_price DECIMAL(10, 2),
    scent_pref TEXT,
    container_type VARCHAR(100),
    capacity VARCHAR(50),
    quantity INTEGER,
    cosmax_pkg_item_id INTEGER,
    export_countries TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 패키징 및 부자재 라이브러리 (Packaging Assets)
CREATE TABLE IF NOT EXISTS cosmax_pkg_items (
    cosmax_pkg_item_id SERIAL PRIMARY KEY,
    type VARCHAR(100), -- Tube, Pump, Cap, etc.
    formulation_compatibility TEXT,
    material VARCHAR(100),
    capacity_options TEXT,
    design_type_mold VARCHAR(50), -- fixed/exclusive
    status VARCHAR(50) DEFAULT 'Available',
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 개발 프로젝트 관리 (Project Lifecycle)
CREATE TABLE IF NOT EXISTS projects (
    project_id SERIAL PRIMARY KEY,
    inquiry_id INTEGER REFERENCES inquiries(inquiry_id) ON DELETE CASCADE,
    status_code VARCHAR(50), -- Pending, Quoting, Contracted, Ordering, Producing, Releasing
    current_phase_percent INTEGER DEFAULT 0 CHECK (current_phase_percent >= 0 AND current_phase_percent <= 100),
    start_at TIMESTAMP WITH TIME ZONE,
    expected_completion_at TIMESTAMP WITH TIME ZONE,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 프로젝트 상태 변경 이력 로그 (Project Status Logs)
CREATE TABLE IF NOT EXISTS project_status_logs (
    log_id SERIAL PRIMARY KEY,
    project_id INTEGER REFERENCES projects(project_id) ON DELETE CASCADE,
    status_code VARCHAR(50) NOT NULL,
    description TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 품질 관리 결과 (Quality Controls)
CREATE TABLE IF NOT EXISTS quality_controls (
    qc_id SERIAL PRIMARY KEY,
    production_schedule_id INTEGER REFERENCES production_schedules(schedule_id) ON DELETE CASCADE,
    project_id INTEGER REFERENCES projects(project_id) ON DELETE CASCADE,
    test_type VARCHAR(100), -- 예: 정기검사, 출하검사 등
    result_status_code VARCHAR(20) DEFAULT '1400000001', -- 검사대기 (Group 14)
    test_log TEXT,
    inspector_name VARCHAR(100),
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 인사이트 리포트 (Insight Reports)
CREATE TABLE IF NOT EXISTS insight_reports (
    report_id SERIAL PRIMARY KEY,
    title VARCHAR(255) NOT NULL,
    insight_pillars_code VARCHAR(20),     -- 인사이트 핵심 필라 (Group 17)
    summary TEXT,                        -- 요약 문구
    content_body TEXT,                   -- 리포트 본문
    cover_image_url TEXT,                -- 표지 이미지
    view_count INTEGER DEFAULT 0,
    published_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 트렌드 키워드 (Trend Keywords & Vector Search)
CREATE TABLE IF NOT EXISTS trend_keywords (
    keyword_id SERIAL PRIMARY KEY,
    keyword VARCHAR(100) NOT NULL,
    trend_type_code VARCHAR(10),         -- 성분, 효능, 제형, 컨셉, 지역 (Group 16)
    trend_score INTEGER DEFAULT 0,       -- 핫 지수
    trend_vector vector(1536),           -- AI 임베딩 벡터
    summary TEXT,                        -- 한 줄 설명
    related_ingredient_ids INTEGER[],    -- 관련 성분들 (No FK)
    related_product_ids INTEGER[],       -- 관련 상품들 (No FK)
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 시장 통계 데이터 (Market Statistics)
CREATE TABLE IF NOT EXISTS market_statistics (
    stat_id SERIAL PRIMARY KEY,
    stat_type VARCHAR(50) NOT NULL,       -- 데이터 성격 (Growth, MarketShare 등)
    target_region VARCHAR(50),            -- 국가/지역 필터링
    target_category VARCHAR(50),          -- 제품군 필터링
    period VARCHAR(20) NOT NULL,          -- 기준 기간 (2025-Q1 등)
    data_json JSONB NOT NULL,             -- 차트용 수치 데이터
    description TEXT,                     -- 전문가 코멘트
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- AI 대화 세션 (AI Chat Sessions)
CREATE TABLE IF NOT EXISTS ai_chat_sessions (
    session_id SERIAL PRIMARY KEY,
    user_id INTEGER REFERENCES buyer(buyer_id) ON DELETE CASCADE,
    title VARCHAR(255),
    status_code VARCHAR(20) DEFAULT '1800000001',
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- AI 대화 상세 (AI Chat Messages)
CREATE TABLE IF NOT EXISTS ai_chat_messages (
    message_id SERIAL PRIMARY KEY,
    session_id INTEGER REFERENCES ai_chat_sessions(session_id) ON DELETE CASCADE,
    role VARCHAR(20) NOT NULL,
    content TEXT NOT NULL,
    metadata JSONB,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- AI 컨설팅 브리프 (AI Consulting Briefs)
CREATE TABLE IF NOT EXISTS ai_consulting_briefs (
    brief_id SERIAL PRIMARY KEY,
    session_id INTEGER REFERENCES ai_chat_sessions(session_id) ON DELETE CASCADE,
    proposed_strategy TEXT,
    recommended_items JSONB,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 제품별 표준 품질 규격 (Standard Product Quality Specs)
CREATE TABLE IF NOT EXISTS product_qc_specs (
    spec_id SERIAL PRIMARY KEY,
    product_id INTEGER REFERENCES product(product_id) ON DELETE CASCADE,
    test_parameter_code VARCHAR(100) NOT NULL, -- 예: pH, 비중, 점도, 성상
    min_value NUMERIC(15, 4),
    max_value NUMERIC(15, 4),
    target_value VARCHAR(100),            -- 수치가 아닌 경우 (예: "특이한 향취가 없을 것")
    unit VARCHAR(20),                     -- 단위 (예: pH, cps, g/mL)
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- QC 상세 시험 결과 (Detailed QC Test Results)
CREATE TABLE IF NOT EXISTS qc_items (
    qc_item_id SERIAL PRIMARY KEY,
    qc_id INTEGER REFERENCES quality_controls(qc_id) ON DELETE CASCADE,
    test_parameter_code VARCHAR(100) NOT NULL,
    spec_range VARCHAR(255),              -- 검사 당시의 기준치 (이력 보존용)
    actual_value VARCHAR(255),            -- 실제 측정치
    result_status_code VARCHAR(10),       -- 1400000003(합격), 1400000004(불합격)
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 검체 보관 관리 (Reference Sample Management)
CREATE TABLE IF NOT EXISTS reference_samples (
    sample_id SERIAL PRIMARY KEY,
    production_schedule_id INTEGER REFERENCES production_schedules(schedule_id) ON DELETE CASCADE,
    storage_location VARCHAR(255),
    sample_quantity VARCHAR(50),          -- 예: "100g", "2ea"
    storage_condition VARCHAR(100) DEFAULT 'Room Temperature',
    collected_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    expiry_date TIMESTAMP WITH TIME ZONE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 시험성적서 발행 이력 (CoA Logs)
CREATE TABLE IF NOT EXISTS coa_logs (
    coa_id SERIAL PRIMARY KEY,
    qc_id INTEGER REFERENCES quality_controls(qc_id) ON DELETE CASCADE,
    coa_no VARCHAR(100) UNIQUE,           -- 성적서 고유 번호
    issued_by_id INTEGER REFERENCES buyer(buyer_id) ON DELETE SET NULL,
    issued_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    recipient_name VARCHAR(255),
    coa_data_snapshot JSONB,              -- 발행 당시의 QC 데이터 스냅샷 (무결성)
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 최종 출하 승인 (Outbound Approvals)
CREATE TABLE IF NOT EXISTS outbound_approvals (
    approval_id SERIAL PRIMARY KEY,
    order_id INTEGER REFERENCES orders(order_id) ON DELETE CASCADE,
    qc_status_code VARCHAR(20),           -- 품질 합격 여부 (Group 14 연동)
    settlement_status_code VARCHAR(20),   -- 정산 완료 여부 (Group 15 연동)
    final_decision VARCHAR(50) DEFAULT 'Pending', -- Pending, Approved, Rejected
    approver_id INTEGER REFERENCES buyer(buyer_id) ON DELETE SET NULL,
    approved_at TIMESTAMP WITH TIME ZONE,
    remarks TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 화장품 기초 원료 카탈로그 (Cosmetics Ingredients Catalog)
CREATE TABLE IF NOT EXISTS ingredients (
    ingredient_id SERIAL PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    inci_name VARCHAR(255),
    cas_no VARCHAR(50),
    function TEXT,
    ewg_grade VARCHAR(10),
    sensory_attribute_vector vector(15), -- AI 매칭을 위한 15차원 원료 감각 벡터
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 원료 감각적 속성 (Ingredient Sensory Attributes)
CREATE TABLE IF NOT EXISTS ingredients_sensory_attribute (
    ingredients_sensory_attribute_id SERIAL PRIMARY KEY,
    ingredient_id INTEGER REFERENCES ingredients(ingredient_id) ON DELETE CASCADE,
    sensory_attribute_code VARCHAR(50),
    point NUMERIC(2, 1) CHECK (point >= 1.0 AND point <= 5.0),
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- R&D 자산 및 지식 기반 (R&D Assets)
CREATE TABLE IF NOT EXISTS cosmax_r_and_d_assets (
    cosmax_r_and_d_asset_id SERIAL PRIMARY KEY,
    asset_type VARCHAR(50), -- Ingredient, Formula, Patent
    name TEXT NOT NULL,
    patent_number VARCHAR(100),
    usage_count INTEGER DEFAULT 0,
    trend_tags TEXT, -- 키워드 해시태그 목록
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 2.4 R&D 상세 데이터 라이브러리 (R&D Deep Data Library)

-- 제형 상세 레시피 (Formula Recipes)
CREATE TABLE IF NOT EXISTS formula_recipes (
    recipe_id SERIAL PRIMARY KEY,
    asset_id INTEGER REFERENCES cosmax_r_and_d_assets(cosmax_r_and_d_asset_id) ON DELETE CASCADE,
    ingredient_id INTEGER REFERENCES ingredients(ingredient_id) ON DELETE CASCADE,
    percentage NUMERIC(5,3) NOT NULL,
    phase VARCHAR(10),
    purpose VARCHAR(100),
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 원료 효능 매핑 (Ingredient Efficacies)
CREATE TABLE IF NOT EXISTS ingredient_efficacies (
    efficacy_id SERIAL PRIMARY KEY,
    ingredient_id INTEGER REFERENCES ingredients(ingredient_id) ON DELETE CASCADE,
    category_id INTEGER REFERENCES category(category_id) ON DELETE CASCADE,
    strength INTEGER CHECK (strength >= 1 AND strength <= 5),
    evidence_level VARCHAR(50),
    is_certified BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 독점 자산 관리 (Exclusive Assets)
CREATE TABLE IF NOT EXISTS exclusive_assets (
    exclusive_id SERIAL PRIMARY KEY,
    asset_id INTEGER REFERENCES cosmax_r_and_d_assets(cosmax_r_and_d_asset_id) ON DELETE CASCADE,
    company_id INTEGER REFERENCES company(company_id) ON DELETE CASCADE,
    exclusive_type VARCHAR(50),
    start_date DATE,
    end_date DATE,
    region VARCHAR(50) DEFAULT 'Global',
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

COMMENT ON TABLE formula_recipes IS 'R&D 자산(제형)의 상세 성분 배합 레시피';
COMMENT ON COLUMN formula_recipes.recipe_id IS '레시피 일련번호';
COMMENT ON COLUMN formula_recipes.asset_id IS 'R&D 자산 ID';
COMMENT ON COLUMN formula_recipes.ingredient_id IS '포함된 원료 ID';
COMMENT ON COLUMN formula_recipes.percentage IS '성분 배합 비율 (%%)';
COMMENT ON COLUMN formula_recipes.phase IS '제조 공정 단계 (A상, B상, C상 등)';
COMMENT ON COLUMN formula_recipes.purpose IS '배합 목적 (유화제, 보습제 등)';

COMMENT ON TABLE ingredient_efficacies IS '원료별 정밀 효능 데이터 (미백, 주름 등)';
COMMENT ON COLUMN ingredient_efficacies.efficacy_id IS '효능 매핑 일련번호';
COMMENT ON COLUMN ingredient_efficacies.ingredient_id IS '관련 원료 ID';
COMMENT ON COLUMN ingredient_efficacies.category_id IS '효능 카테고리 ID (category 참조)';
COMMENT ON COLUMN ingredient_efficacies.strength IS '효능 강도 (1-5점)';
COMMENT ON COLUMN ingredient_efficacies.evidence_level IS '근거 수준 (임상, In-vitro 등)';
COMMENT ON COLUMN ingredient_efficacies.is_certified IS '식약처 고시 인증 성분 여부';

COMMENT ON TABLE exclusive_assets IS '자산별 독점권 및 소유권 관리';
COMMENT ON COLUMN exclusive_assets.exclusive_id IS '독점 관리 일련번호';
COMMENT ON COLUMN exclusive_assets.asset_id IS '독점 대상 자산 ID';
COMMENT ON COLUMN exclusive_assets.company_id IS '독점권을 가진 업체 ID';
COMMENT ON COLUMN exclusive_assets.exclusive_type IS '독점 유형 (특허 소유, 독점 계약 등)';
COMMENT ON COLUMN exclusive_assets.region IS '독점 지역 범위';
COMMENT ON COLUMN exclusive_assets.is_active IS '현재 활성화 여부';


-- 3. 유통 및 주문 관리 (Distribution & Orders)

-- 글로벌 브랜드 정보
CREATE TABLE IF NOT EXISTS brands (
    brand_id SERIAL PRIMARY KEY,
    company_id INTEGER REFERENCES company(company_id) ON DELETE SET NULL,
    brand_name VARCHAR(255) NOT NULL,
    logo_url TEXT,
    brand_desc TEXT,
    partnership_type VARCHAR(100),
    official_status BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 도매 상품 정보
CREATE TABLE IF NOT EXISTS product (
    product_id SERIAL PRIMARY KEY,
    brand_id INTEGER REFERENCES brands(brand_id) ON DELETE SET NULL,
    category_id INTEGER,
    sku VARCHAR(100) UNIQUE,
    product_name TEXT NOT NULL,
    description TEXT,
    retail_price DECIMAL(12, 2),
    wholesale_base_price DECIMAL(12, 2),
    moq INTEGER DEFAULT 1,
    stock_quantity INTEGER DEFAULT 0,
    status VARCHAR(50), -- In_Stock, Out_of_Stock, U_Quick_Ready
    sensory_attribute_vector vector(15),
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 제품 감각적 속성 (Sensory Attributes)
CREATE TABLE IF NOT EXISTS product_sensory_attribute (
    product_sensory_attribute_id SERIAL PRIMARY KEY,
    product_id INTEGER REFERENCES product(product_id) ON DELETE CASCADE,
    attribute_code VARCHAR(50),
    attribute_name VARCHAR(100),
    point NUMERIC(2, 1) CHECK (point >= 1.0 AND point <= 5.0),
    "desc" TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 3.1 디지털 조색 및 색상 마스터 (Color Management)
CREATE TABLE IF NOT EXISTS color_master (
    color_id SERIAL PRIMARY KEY,
    product_id INTEGER REFERENCES product(product_id) ON DELETE CASCADE,
    color_name VARCHAR(255) NOT NULL,
    hex_code VARCHAR(7),
    lab_l NUMERIC(5,2),
    lab_a NUMERIC(5,2),
    lab_b NUMERIC(5,2),
    illuminant VARCHAR(20) DEFAULT 'D65',
    observer VARCHAR(20) DEFAULT '10deg',
    tolerance NUMERIC(3,2) DEFAULT 1.0,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 3.2 색상 측정 및 품질 관리 이력 (Color Measurement Log)
CREATE TABLE IF NOT EXISTS color_measurement_log (
    measurement_id SERIAL PRIMARY KEY,
    color_id INTEGER REFERENCES color_master(color_id) ON DELETE CASCADE,
    project_id INTEGER REFERENCES projects(project_id) ON DELETE SET NULL,
    measured_l NUMERIC(5,2),
    measured_a NUMERIC(5,2),
    measured_b NUMERIC(5,2),
    delta_e NUMERIC(5,2),
    is_pass BOOLEAN,
    measured_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

COMMENT ON TABLE color_master IS '제품별 표준 색상 정보 (Digital Color Master)';
COMMENT ON COLUMN color_master.color_id IS '색상 고유 식별 번호';
COMMENT ON COLUMN color_master.product_id IS '연관 제품 ID';
COMMENT ON COLUMN color_master.color_name IS '색상 명칭';
COMMENT ON COLUMN color_master.hex_code IS 'UI 표시용 HEX 코드';
COMMENT ON COLUMN color_master.lab_l IS '기준 명도 (L*)';
COMMENT ON COLUMN color_master.lab_a IS '기준 색도 (a*)';
COMMENT ON COLUMN color_master.lab_b IS '기준 색도 (b*)';
COMMENT ON COLUMN color_master.illuminant IS '표준 광원 (D65 등)';
COMMENT ON COLUMN color_master.observer IS '표준 관측자 (2deg, 10deg)';
COMMENT ON COLUMN color_master.tolerance IS '색차 합격 허용 범위';

COMMENT ON TABLE color_measurement_log IS '실제 색상 측정 및 품질 관리 로그';
COMMENT ON COLUMN color_measurement_log.measurement_id IS '측정 이력 고유 ID';
COMMENT ON COLUMN color_measurement_log.color_id IS '관련 표준 색상 ID';
COMMENT ON COLUMN color_measurement_log.project_id IS '연관 프로젝트 ID';
COMMENT ON COLUMN color_measurement_log.measured_l IS '측정 명도 (L*)';
COMMENT ON COLUMN color_measurement_log.measured_a IS '측정 색도 (a*)';
COMMENT ON COLUMN color_measurement_log.measured_b IS '측정 색도 (b*)';
COMMENT ON COLUMN color_measurement_log.delta_e IS '계산된 색차 (Target vs Measured)';
COMMENT ON COLUMN color_measurement_log.is_pass IS '색차 기준 합격 여부';

-- 도매 가격 티어링 정책
CREATE TABLE IF NOT EXISTS price_tiers (
    price_tier_id SERIAL PRIMARY KEY,
    product_id INTEGER REFERENCES product(product_id) ON DELETE CASCADE,
    min_quantity INTEGER NOT NULL,
    unit_price DECIMAL(12, 2) NOT NULL,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 글로벌 주문 정보
CREATE TABLE IF NOT EXISTS orders (
    order_id SERIAL PRIMARY KEY,
    buyer_id INTEGER REFERENCES buyer(buyer_id),
    order_status VARCHAR(50), -- Processing, Shipped, Delivered, Canceled
    total_amount DECIMAL(15, 2),
    currency VARCHAR(10) DEFAULT 'USD',
    shipping_method VARCHAR(100),
    tracking_num VARCHAR(100),
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 주문 상세 항목
CREATE TABLE IF NOT EXISTS order_items (
    order_item_id SERIAL PRIMARY KEY,
    order_id INTEGER REFERENCES orders(order_id) ON DELETE CASCADE,
    product_id INTEGER REFERENCES product(product_id),
    quantity INTEGER NOT NULL,
    unit_price_at_order DECIMAL(12, 2) NOT NULL,
    subtotal DECIMAL(15, 2),
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 특수 세일 및 아울렛 딜 (U-Outlet)
CREATE TABLE IF NOT EXISTS outlet_deals (
    outlet_deal_id SERIAL PRIMARY KEY,
    product_id INTEGER REFERENCES product(product_id) ON DELETE CASCADE,
    discount_rate DECIMAL(5, 2), -- ex: 25.50 (25.5%%)
    start_at TIMESTAMP WITH TIME ZONE,
    end_at TIMESTAMP WITH TIME ZONE,
    flash_sale_status VARCHAR(50), -- Active, Expired
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

